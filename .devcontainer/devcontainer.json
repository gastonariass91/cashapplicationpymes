{
  "name": "ReconciliationApp (.NET 8)",
  "image": "mcr.microsoft.com/devcontainers/dotnet:1-8.0",
  "forwardPorts": [5081, 8080],
  "portsAttributes": {
    "8080": {
      "label": "Frontend",
      "onAutoForward": "openBrowser"
    },
    "5081": {
      "label": "API"
    }
  },
  "postCreateCommand": "dotnet --info",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "humao.rest-client"
      ]
    }
  }
}
