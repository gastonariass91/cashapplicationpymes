@using ReconciliationApp.Frontend.Models
@using ReconciliationApp.Frontend.State

<div class="card assistant">
  <div class="panelHead">
    <div class="assistantHeaderText">
      <b>Resumen de vista</b>
      <span>Información contextual de la conciliación</span>
    </div>
  </div>

  <div class="assistantBody">
    <div class="assistantStats">
      <div class="statBox">
        <div class="statLabel">Seleccionadas</div>
        <div class="statValue">@Store.Selected.Count</div>
      </div>

      <div class="statBox">
        <div class="statLabel">Visibles</div>
        <div class="statValue">@Store.VisibleRows().Count()</div>
      </div>

      <div class="statBox">
        <div class="statLabel">Automáticos</div>
        <div class="statValue">@Store.AutoCount</div>
      </div>
    </div>

    <div class="assistantAdvice">
      <div class="assistantHint">
        <b>Recomendación</b>
        <div class="assistantText">
          Empezá por coincidencias de <b>Alta confianza</b>. Luego revisá coincidencias de <b>Media</b> si el caso es evidente.
        </div>
      </div>

      <div class="assistantNext compactNext">
        <b>Próximo paso</b>
        <div class="assistantText">
          @if (Store.PendingCount > 0)
          {
            <span>Pendientes por revisar.</span>
          }
          else if (Store.ExceptionCount > 0)
          {
            <span>Excepciones por resolver.</span>
          }
          else
          {
            <span>Listo para confirmar.</span>
          }
        </div>
      </div>
    </div>
  </div>
</div>

@code {
  [Parameter, EditorRequired] public ReconciliationStore Store { get; set; } = default!;
}
