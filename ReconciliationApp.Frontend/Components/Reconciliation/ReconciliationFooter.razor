@using ReconciliationApp.Frontend.Models
@using ReconciliationApp.Frontend.State

<div class="footerBar">
  <div class="footerInner">
    <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center; color:var(--muted); font-size:12px;">
      <span><b>Vista:</b> @ViewName()</span>
      <span>·</span>
      <span><b>Seleccionada:</b> @(Store.SelectedRow is null ? "—" : $"Deuda #{Store.SelectedRow.DebtRowNumber} ↔ Pago #{Store.SelectedRow.PaymentRowNumber}")</span>
      <span>·</span>
      <span><b>Estado run:</b> @(Store.CanConfirm ? "Listo para confirmar" : "Requiere resolución")</span>
    </div>

    <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <button class="btn primary"
              disabled="@(Store.View!=ReconciliationView.Auto)"
              @onclick="OnAcceptVisible">
        Aceptar visibles
      </button>

      <button class="btn primary"
              disabled="@(!Store.CanConfirm)">
        Confirmar conciliación
      </button>
    </div>
  </div>
</div>

@code {
  [Parameter, EditorRequired] public ReconciliationStore Store { get; set; } = default!;
  [Parameter] public EventCallback AcceptVisibleRequested { get; set; }

  string ViewName()
    => Store.View switch
    {
      ReconciliationView.Auto => "Automáticas",
      ReconciliationView.Pending => "Pendientes",
      _ => "Excepciones"
    };

  Task OnAcceptVisible() => AcceptVisibleRequested.InvokeAsync();
}
