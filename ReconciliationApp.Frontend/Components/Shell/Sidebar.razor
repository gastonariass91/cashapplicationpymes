@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Routing
@using ReconciliationApp.Frontend.State
@inject LayoutState Layout
@inject AuthState Auth
@implements IDisposable

@if (Layout.IsSidebarOpen)
{
    <div class="shellOverlay show" @onclick="Layout.CloseSidebar" aria-hidden="true"></div>
}

<aside id="appSidebar"
       class="sidebar @(Layout.IsSidebarOpen ? "open" : "")"
       aria-hidden="@(Layout.IsSidebarOpen ? "false" : "true")"
       @onclick:stopPropagation="true">

    <div class="sTop">
        <div class="brandMark">
            <div class="companyLogo">AG</div>
            <div class="brandText">
                <b>@(Auth.CompanyName)</b>
                <span>Conciliación PyMEs</span>
            </div>
        </div>

        <button type="button"
                class="iconBtn"
                title="Cerrar menú"
                aria-label="Cerrar menú"
                @onclick="Layout.CloseSidebar">
            <svg class="icon" viewBox="0 0 24 24">
                <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
        </button>
    </div>

    <nav class="navMenu" aria-label="Navegación principal">
        <NavLink class="navItem" href="/reconciliation" Match="NavLinkMatch.Prefix" @onclick="Layout.CloseSidebar">
            <svg class="icon" viewBox="0 0 24 24">
                <path d="M3 12l9-9 9 9"/>
                <path d="M9 21V9h6v12"/>
            </svg>
            <div class="text">
                <div class="label">Conciliación</div>
                <div class="sub">Runs y resultados</div>
            </div>
        </NavLink>

        <NavLink class="navItem" href="/imports" Match="NavLinkMatch.Prefix" @onclick="Layout.CloseSidebar">
            <svg class="icon" viewBox="0 0 24 24">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <path d="M7 10l5 5 5-5"/>
                <path d="M12 15V3"/>
            </svg>
            <div class="text">
                <div class="label">Importaciones</div>
                <div class="sub">Deudas y pagos</div>
            </div>
        </NavLink>

        <NavLink class="navItem" href="/reports" Match="NavLinkMatch.Prefix" @onclick="Layout.CloseSidebar">
            <svg class="icon" viewBox="0 0 24 24">
                <path d="M4 19V5"/>
                <path d="M4 5h16"/>
                <path d="M20 5v14"/>
                <path d="M4 19h16"/>
            </svg>
            <div class="text">
                <div class="label">Reportes</div>
                <div class="sub">Exportaciones</div>
            </div>
        </NavLink>
    </nav>

    <div class="sBottom">
        <div class="userCard">
            <div class="userInfo">
                <div class="avatar">GA</div>
                <div class="userMeta">
                    <b>Gasti</b>
                    <span>Administración</span>
                </div>
            </div>

            <button type="button"
                    class="iconBtn"
                    title="Configuración"
                    aria-label="Configuración">
                <svg class="icon" viewBox="0 0 24 24">
                    <path d="M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z"/>
                    <path d="M19.4 15a7.8 7.8 0 0 0 .1-1l2-1.5-2-3.4-2.4 1a7.7 7.7 0 0 0-1.7-1l-.3-2.6H10l-.3 2.6a7.7 7.7 0 0 0-1.7 1l-2.4-1-2 3.4 2 1.5a7.8 7.8 0 0 0 0 2l-2 1.5 2 3.4 2.4-1a7.7 7.7 0 0 0 1.7 1l.3 2.6h4.1l.3-2.6a7.7 7.7 0 0 0 1.7-1l2.4 1 2-3.4-2-1.5z"/>
                </svg>
            </button>
        </div>

        <div class="shortcutHint">
            Atajos: <span class="mono">⌘K</span> buscar ·
            <span class="mono">A</span> aceptar ·
            <span class="mono">X</span> excepción ·
            <span class="mono">N</span> siguiente ·
            <span class="mono">Esc</span> cerrar
        </div>
    </div>
</aside>

@code {
    protected override void OnInitialized()
    {
        Layout.OnChange += HandleLayoutChange;
    }

    private void HandleLayoutChange()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Layout.OnChange -= HandleLayoutChange;
    }
}
