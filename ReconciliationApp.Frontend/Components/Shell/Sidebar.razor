@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Routing
@using ReconciliationApp.Frontend.State
@inject LayoutState Layout
@inject AuthState Auth
@inject NavigationManager Nav
@implements IDisposable

@if (Layout.IsSidebarOpen)
{
    <div class="shellOverlay show" @onclick="Layout.CloseSidebar" aria-hidden="true"></div>
}

<aside id="appSidebar"
       class="sidebar @(Layout.IsSidebarOpen ? "open" : "")"
       aria-hidden="@(Layout.IsSidebarOpen ? "false" : "true")"
       @onclick:stopPropagation="true">

    <div class="sTop">
        <div class="brandMark">
            <div class="companyLogo">@(string.IsNullOrEmpty(Auth.CompanyName) ? "CA" : Auth.CompanyName.Substring(0, Math.Min(2, Auth.CompanyName.Length)).ToUpper())</div>
            <div class="brandText">
                <b>@(Auth.CompanyName)</b>
            </div>
        </div>
        <button type="button" class="iconBtn" title="Cerrar menú" aria-label="Cerrar menú" @onclick="Layout.CloseSidebar">
            <svg class="icon" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
    </div>

    <nav class="navMenu" aria-label="Navegación principal">
        <NavLink class="navItem" href="/reconciliation" Match="NavLinkMatch.Prefix" @onclick="Layout.CloseSidebar">
            <svg class="icon" viewBox="0 0 24 24"><path d="M3 12l9-9 9 9"/><path d="M9 21V9h6v12"/></svg>
            <div class="text"><div class="label">Conciliación</div><div class="sub">Runs y resultados</div></div>
        </NavLink>
        <NavLink class="navItem" href="/imports" Match="NavLinkMatch.Prefix" @onclick="Layout.CloseSidebar">
            <svg class="icon" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>
            <div class="text"><div class="label">Importaciones</div><div class="sub">Deudas y pagos</div></div>
        </NavLink>
        <NavLink class="navItem" href="/customers" Match="NavLinkMatch.Prefix" @onclick="Layout.CloseSidebar">
            <svg class="icon" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <div class="text"><div class="label">Clientes</div><div class="sub">Directorio</div></div>
        </NavLink>
        <NavLink class="navItem" href="/reports" Match="NavLinkMatch.Prefix" @onclick="Layout.CloseSidebar">
            <svg class="icon" viewBox="0 0 24 24"><path d="M4 19V5"/><path d="M4 5h16"/><path d="M20 5v14"/><path d="M4 19h16"/></svg>
            <div class="text"><div class="label">Reportes</div><div class="sub">Exportaciones</div></div>
        </NavLink>
    </nav>

    <div class="sBottom">
        <div class="userCard">
            <div class="userInfo">
                <div class="avatar">@(Auth.FullName?.Substring(0,2).ToUpper() ?? "US")</div>
                <div class="userMeta">
                    <b>@(Auth.FullName ?? "Usuario")</b>
                    <span>@(Auth.Role ?? "")</span>
                </div>
            </div>
            <button type="button" class="iconBtn" title="Cerrar sesión" aria-label="Cerrar sesión" @onclick="Logout">
                <svg class="icon" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </button>
        </div>
    </div>
</aside>

@code {
    protected override void OnInitialized()
    {
        Layout.OnChange += HandleLayoutChange;
    }

    private void Logout()
    {
        Auth.ClearUser();
        Nav.NavigateTo("/login");
    }

    private void HandleLayoutChange()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Layout.OnChange -= HandleLayoutChange;
    }
}
