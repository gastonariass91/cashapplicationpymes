@using ReconciliationApp.Frontend.State
@inject LayoutState Layout
@implements IDisposable

<div class="app">  <!-- DEBUG menu button (always on top) -->
  <!-- Sidebar overlay -->
  <div class="overlay @(Layout.IsSidebarOpen ? "show" : "")"
       style="z-index:900000;"
       @onclick="Layout.CloseSidebar"></div>

  <!-- Sidebar -->
  <aside class="sidebar @(Layout.IsSidebarOpen ? "open" : "")"
         style="z-index:950000;">
    <div style="display:flex; align-items:center; justify-content:space-between; padding:12px; border-bottom:1px solid rgba(255,255,255,.08);">
      <strong>Menú</strong>
      <button type="button" class="iconBtn" title="Cerrar" @onclick="Layout.CloseSidebar">✕</button>
    </div>

    <div style="padding:12px;">
      <NavMenu />
    </div>
  </aside>

  <!-- Main content -->
  <main class="main">
    @ChildContent
  </main>

</div>

@code {
  [Parameter] public RenderFragment? ChildContent { get; set; }  protected override void OnInitialized()
  {
    Layout.OnChange += StateHasChanged;
  }

  public void Dispose()
  {
    Layout.OnChange -= StateHasChanged;
  }}
