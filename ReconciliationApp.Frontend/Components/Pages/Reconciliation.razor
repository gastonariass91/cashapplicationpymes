@page "/reconciliation"
@using ReconciliationApp.Frontend.Models
@using ReconciliationApp.Frontend.State
@inject ReconciliationStore Store

<PageTitle>Conciliación</PageTitle>

<div class="drawerOverlay @(Store.DrawerOpen ? "show" : "")" @onclick="CloseDrawer"></div>
    <div class="wrap">

      <div class="kpis">
        <div class="card kpi">
          <div class="label">Deudas <span class="mini">@($"{Store.DebtsRowsTotal} filas")</span></div>
          <div class="value">@ReconciliationStore.Money(Store.DebtsAmtTotal)</div>
        </div>
        <div class="card kpi">
          <div class="label">Pagos <span class="mini">@($"{Store.PaysRowsTotal} filas")</span></div>
          <div class="value">@ReconciliationStore.Money(Store.PaysAmtTotal)</div>
        </div>
        <div class="card kpi">
          <div class="label">Automáticas <span class="mini" style="color:rgba(187,255,212,.95)">Reglas</span></div>
          <div class="value">@Store.AutoCount</div>
        </div>
        <div class="card kpi">
          <div class="label">Pendientes <span class="mini" style="color:rgba(255,232,191,.98)">Revisar</span></div>
          <div class="value">@Store.PendingCount</div>
        </div>
        <div class="card kpi">
          <div class="label">Excepciones <span class="mini" style="color:rgba(255,203,203,.98)">Decidir</span></div>
          <div class="value">@Store.ExceptionCount</div>
        </div>
      </div>

      <div class="tabs">
        <button class="tab @(Store.View==ReconciliationView.Auto?"active":"")" @onclick="() => SetView(ReconciliationView.Auto)">Automáticas</button>
        <button class="tab @(Store.View==ReconciliationView.Pending?"active":"")" @onclick="() => SetView(ReconciliationView.Pending)">Pendientes</button>
        <button class="tab @(Store.View==ReconciliationView.Exceptions?"active":"")" @onclick="() => SetView(ReconciliationView.Exceptions)">Excepciones</button>

        @if (Store.View == ReconciliationView.Auto)
        {
          <div class="pills" title="Filtro por confianza (solo Automáticas)">
            <div class="pill @(Store.ConfFilter=="all"?"active":"")" @onclick="SetConfAll">Todas</div>
            <div class="pill @(Store.ConfFilter=="Alta"?"active":"")" @onclick="SetConfAlta">Alta</div>
            <div class="pill @(Store.ConfFilter=="Alta+Media"?"active":"")" @onclick="SetConfAltaMedia">Alta+Media</div>
          </div>
        }

        <div class="tip">Tip: aceptá Automáticas (Alta/Media) y pasá a Pendientes.</div>
      </div>

      <div class="layout">
        <div class="card">
          <div class="panelHead">
            <div style="display:flex; flex-direction:column; gap:2px; min-width:0;">
              <b>@TableTitle()</b>
              <span>@TableSubtitle()</span>
            </div>
            <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
              <div class="search">
                <span style="color:var(--muted)">🔎</span>
                <input value="@Store.Query" @oninput="OnQuery" placeholder="Buscar por cliente, monto, regla, tipo…" />
                <span class="hint mono">⌘K</span>
              </div>
              <button class="btn" @onclick="ClearSelection">Limpiar</button>
            </div>
          </div>

          <table class="table">
            <thead>
              <tr>
                <th class="sel" style="@(Store.View==ReconciliationView.Auto ? "" : "visibility:hidden")" title="Seleccionar todo visible">
                  <span class="checkbox">
                    <input type="checkbox"
                           checked="@Store.AllVisibleSelected()"
                           @onchange="ToggleAll" />
                  </span>
                </th>
                <th>Riesgo</th>
                <th>Caso</th>
                <th>Cliente</th>
                <th>Monto / Δ</th>
                <th>Sugerencia</th>
                <th>Estado</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var r in Store.VisibleRows())
              {
                var key = r.Key;
                <tr class="@(Store.SelectedKey==key ? "selected" : "")" @onclick="() => OpenDrawer(key)">
                  <td class="sel">
                    @if (Store.View==ReconciliationView.Auto)
                    {
                      <span class="checkbox" @onclick:stopPropagation="true">
                        <input type="checkbox" checked="@Store.Selected.Contains(key)" @onchange="(e)=>ToggleOne(key,e)" />
                      </span>
                    }
                  </td>
                  <td>@(RiskCell(r))</td>
                  <td>
                    <div style="display:flex; align-items:center; gap:10px;">
                      <span class="typeBadge" title="@TypeLabel(r.Type)">@TypeIcon(r.Type)</span>
                      <div style="display:flex; flex-direction:column; min-width:0;">
                        <b class="mono">#@r.DebtRowNumber ↔ #@r.PaymentRowNumber</b>
                        <span class="cellSub">@TypeLabel(r.Type) · @r.Rule</span>
                      </div>
                    </div>
                  </td>
                  <td>
                    <b>@r.Customer</b>
                    <span class="cellSub">@r.Evidence</span>
                  </td>
                  <td>
                    <b>@ReconciliationStore.Money(r.DebtAmount)</b>
                    <span class="cellSub">Pago @ReconciliationStore.Money(r.PaymentAmount) · Δ <span class="delta @DeltaClass(r.Delta) mono">@DeltaText(r.Delta)</span></span>
                  </td>
                  <td>@(SuggestionChip(r))</td>
                  <td>@(StatusChip(r.Status))</td>
                </tr>
              }
            </tbody>
          </table>
        </div>

        <div class="side card">
          <div class="panelHead">
            <div style="display:flex; flex-direction:column; gap:2px;">
              <b>Asistente</b>
              <span>Acción guiada (bulk)</span>
            </div>
          </div>

          <div class="box">
            <p class="sectionTitle">Aceptación en bloque</p>
            <div class="callout" style="margin-bottom:10px;">
              <b>Recomendación:</b> aceptá <span class="mono">Alta</span> y (opcional) <span class="mono">Media</span>.
            </div>

            <div class="kv">
              <div class="k">Seleccionadas</div><div><b>@Store.Selected.Count</b></div>
              <div class="k">Visibles (filtro)</div><div><b>@Store.VisibleRows().Count()</b></div>
              <div class="k">Auto totales</div><div><b>@Store.AutoCount</b></div>
            </div>

            <div style="display:flex; gap:8px; margin-top:12px; flex-wrap:wrap;">
              <button class="btn primary" disabled="@(Store.Selected.Count==0 || Store.View!=ReconciliationView.Auto)" @onclick="AcceptSelected">Aceptar seleccionadas</button>
              <button class="btn" disabled="@(Store.View!=ReconciliationView.Auto || !Store.VisibleRows().Any())" @onclick="AcceptVisible">Aceptar visibles</button>
            </div>
          </div>
        </div>
      </div>

    </div>
<aside class="drawer @(Store.DrawerOpen ? "open" : "")" aria-hidden="@(!Store.DrawerOpen)">
  <div class="drawerHead">
    <div style="display:flex; flex-direction:column; gap:2px; min-width:0;">
      <b>@(Store.SelectedRow is null ? "Resolver caso" : $"Resolver · {Store.SelectedRow.Customer}")</b>
      <span class="small">@DrawerSub()</span>
    </div>
    <button class="iconBtn" title="Cerrar" @onclick="CloseDrawer">
      <svg class="icon" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div class="drawerBody">
    @if (Store.SelectedRow is null)
    {
      <div class="callout">Seleccioná una fila para ver el detalle.</div>
    }
    else
    {
      var r = Store.SelectedRow;
      <div class="callout"><b>Sugerencia:</b> @r!.Suggestion <span class="small">· Conf @r.Confidence</span></div>

      <div class="list" style="margin-top:12px;">
        <div class="row">
          <div class="meta"><b>Resumen</b><small>Deuda #@r.DebtRowNumber (@ReconciliationStore.Money(r.DebtAmount)) ↔ Pago #@r.PaymentRowNumber (@ReconciliationStore.Money(r.PaymentAmount)) · Δ @r.Delta</small></div>
          <span class="chip neutral">@r.Status</span>
        </div>
        <div class="row">
          <div class="meta"><b>Evidencia</b><small>@r.Evidence</small></div>
          <span class="chip neutral">@r.Confidence</span>
        </div>
        <div class="row">
          <div class="meta"><b>Regla aplicada</b><small>@r.Rule</small></div>
          <span class="chip neutral">@TypeLabel(r.Type)</span>
        </div>
      </div>
    }
  </div>

  <div class="drawerFooter">
    <span style="flex:1"></span>
    <button class="btn danger" disabled="@(Store.SelectedRow is null)" @onclick="MarkException">Marcar excepción</button>
    <button class="btn primary" disabled="@(Store.SelectedRow is null)" @onclick="AcceptOne">Aceptar</button>
  </div>
</aside>

<div class="footerBar">
  <div class="footerInner">
    <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center; color:var(--muted); font-size:12px;">
      <span><b>Vista:</b> @ViewName()</span>
      <span>·</span>
      <span><b>Seleccionada:</b> @(Store.SelectedRow is null ? "—" : $"Deuda #{Store.SelectedRow.DebtRowNumber} ↔ Pago #{Store.SelectedRow.PaymentRowNumber}")</span>
      <span>·</span>
      <span><b>Estado run:</b> @(Store.CanConfirm ? "Listo para confirmar" : "Requiere resolución")</span>
    </div>

    <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <button class="btn primary" disabled="@(Store.View!=ReconciliationView.Auto)" @onclick="AcceptVisible">Aceptar visibles</button>
      <button class="btn primary" disabled="@(!Store.CanConfirm)">Confirmar conciliación</button>
    </div>
  </div>
</div>

@code {
  void SetView(ReconciliationView v) { Store.SetView(v); StateHasChanged(); }

  void SetConfAll() { Store.SetConfFilter("all"); StateHasChanged(); }
  void SetConfAlta() { Store.SetConfFilter("Alta"); StateHasChanged(); }
  void SetConfAltaMedia() { Store.SetConfFilter("Alta+Media"); StateHasChanged(); }

  void OnQuery(ChangeEventArgs e) { Store.SetQuery(e.Value?.ToString() ?? ""); StateHasChanged(); }

  void ToggleOne(string key, ChangeEventArgs e)
  {
      var on = e.Value is bool b && b;
      Store.ToggleSelected(key, on);
      StateHasChanged();
  }

  void ToggleAll(ChangeEventArgs e)
  {
      var on = e.Value is bool b && b;
      Store.SelectAllVisible(on);
      StateHasChanged();
  }

  void ClearSelection()
  {
      Store.Selected.Clear();
      Store.CloseDrawer();
      StateHasChanged();
  }

  void OpenDrawer(string key) { Store.OpenDrawer(key); StateHasChanged(); }
  void CloseDrawer() { Store.CloseDrawer(); StateHasChanged(); }

  void AcceptSelected() { Store.AcceptSelected(); StateHasChanged(); }
  void AcceptVisible() { Store.AcceptVisible(); StateHasChanged(); }

  void AcceptOne()
  {
      if (Store.SelectedKey is null) return;
      Store.AcceptByKey(Store.SelectedKey);
      StateHasChanged();
  }

  void MarkException()
  {
      if (Store.SelectedKey is null) return;
      Store.ExceptionByKey(Store.SelectedKey);
      StateHasChanged();
  }

  string ViewName() => Store.View switch
  {
      ReconciliationView.Auto => "Automáticas",
      ReconciliationView.Pending => "Pendientes",
      _ => "Excepciones"
  };

  string TableTitle() => Store.View switch
  {
      ReconciliationView.Auto => "Automáticas · operable",
      ReconciliationView.Pending => "Pendientes · cola",
      _ => "Excepciones · revisión"
  };

  string TableSubtitle() => Store.View switch
  {
      ReconciliationView.Auto => "Seleccioná y aceptá en bloque. Click en fila para resolver en drawer.",
      ReconciliationView.Pending => "Resolvé rápido con drawer.",
      _ => "Investigá en drawer y decidí."
  };

  string DrawerSub()
  {
      var r = Store.SelectedRow;
      if (r is null) return "Click en una fila para ver evidencia";
      return $"{TypeLabel(r.Type)} · {r.Rule} · Conf {r.Confidence}";
  }

  static string TypeIcon(ReconMatchType t) => t switch
  {
      ReconMatchType.Exact => "=",
      ReconMatchType.Partial => "≋",
      ReconMatchType.Multi => "⇄",
      ReconMatchType.Dup => "⧉",
      ReconMatchType.Amb => "?",
      _ => "∅"
  };

  static string TypeLabel(ReconMatchType t) => t switch
  {
      ReconMatchType.Exact => "Exacto",
      ReconMatchType.Partial => "Parcial",
      ReconMatchType.Multi => "Multi",
      ReconMatchType.Dup => "Duplicado",
      ReconMatchType.Amb => "Ambiguo",
      _ => "Sin match"
  };

  static string DeltaText(decimal d) => (d > 0 ? "+" : "") + d.ToString("0");
  static string DeltaClass(decimal d)
  {
      var abs = Math.Abs(d);
      if (abs == 0) return "ok";
      if (abs <= 50) return "warn";
      return "bad";
  }

  static string RiskLevel(ReconciliationRow r)
  {
      if (r.Status == RowStatus.Exception) return "high";
      if (r.Type is ReconMatchType.Dup or ReconMatchType.Amb or ReconMatchType.NoMatch) return "high";
      if (r.Type == ReconMatchType.Partial || Math.Abs(r.Delta) > 0) return "mid";
      if (r.Confidence == Confidence.Alta && Math.Abs(r.Delta) == 0) return "low";
      return "mid";
  }

  MarkupString RiskCell(ReconciliationRow r)
  {
      var rk = RiskLevel(r);
      var label = rk == "low" ? "Bajo" : rk == "mid" ? "Medio" : "Alto";
      return (MarkupString)$@"
        <span class=""risk {rk}"">
          <span class=""riskDot""></span>
          {label}
          <small>· {r.Confidence}</small>
        </span>";
  }

  MarkupString StatusChip(RowStatus s)
  {
      return s switch
      {
          RowStatus.Ok => (MarkupString)@"<span class=""chip good"">Auto</span>",
          RowStatus.Pending => (MarkupString)@"<span class=""chip warn"">Pendiente</span>",
          _ => (MarkupString)@"<span class=""chip bad"">Excepción</span>"
      };
  }

  MarkupString SuggestionChip(ReconciliationRow r)
  {
      var rk = RiskLevel(r);
      var cls = rk == "high" ? "bad" : rk == "mid" ? "warn" : "good";
      return (MarkupString)$@"<span class=""chip {cls}"">{r.Suggestion}</span>";
  }
}
