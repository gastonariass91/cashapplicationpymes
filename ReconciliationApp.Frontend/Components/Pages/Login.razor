@page "/login"
@layout EmptyLayout
@inject AuthApiClient AuthClient
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>Iniciar sesión · Cash Application</PageTitle>

<div class="login-split">

    <!-- Panel izquierdo: marca -->
    <div class="split-left">
        <div class="split-left-inner">
            <div class="brand-mark">
                <svg width="22" height="22" viewBox="0 0 20 20" fill="none">
                    <path d="M10 2L16 5.5V13L10 16.5L4 13V5.5L10 2Z" stroke="white" stroke-width="1.25" stroke-linejoin="round"/>
                    <path d="M10 2V16.5M4 5.5L16 13M16 5.5L4 13" stroke="white" stroke-width="0.75" stroke-opacity="0.5"/>
                </svg>
            </div>
            <h2>Cash Application</h2>
            <p>Conciliación de pagos para PyMES</p>

            <div class="brand-features">
                <div class="feature-item">
                    <div class="feature-dot"></div>
                    <span>Importá deudas y pagos desde CSV</span>
                </div>
                <div class="feature-item">
                    <div class="feature-dot"></div>
                    <span>Conciliación automática al cargar</span>
                </div>
                <div class="feature-item">
                    <div class="feature-dot"></div>
                    <span>Revisá, aceptá o marcá excepciones</span>
                </div>
                <div class="feature-item">
                    <div class="feature-dot"></div>
                    <span>Confirmá el cierre con un click</span>
                </div>
            </div>
        </div>

        <div class="split-footer-brand">Cash Application PyMES · v0.1</div>
    </div>

    <!-- Panel derecho: form -->
    <div class="split-right">
        <div class="form-wrapper">
            <div class="form-header">
                <h1>Bienvenido</h1>
                <p>Ingresá tus credenciales para continuar</p>
            </div>

            @if (_error is not null)
            {
                <div class="login-error">
                    <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/>
                    </svg>
                    @_error
                </div>
            }

            <div class="form-group">
                <label for="email">Email</label>
                <input id="email" type="email" class="form-input"
                       placeholder="usuario@empresa.com"
                       @bind="_email" @onkeydown="OnKeyDown"
                       disabled="@_loading" />
            </div>

            <div class="form-group">
                <label for="password">Contraseña</label>
                <input id="password" type="password" class="form-input"
                       placeholder="••••••••"
                       @bind="_password" @onkeydown="OnKeyDown"
                       disabled="@_loading" />
            </div>

            <button class="login-btn" @onclick="HandleLogin" disabled="@_loading">
                @if (_loading)
                {
                    <span class="spinner"></span>
                    <span>Ingresando...</span>
                }
                else
                {
                    <span>Ingresar</span>
                    <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
                    </svg>
                }
            </button>
        </div>
    </div>
</div>

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; overflow: hidden; }

    .login-split {
        position: fixed;
        inset: 0;
        display: flex;
    }

    /* Panel izquierdo */
    .split-left {
        width: 42%;
        background: linear-gradient(160deg, #1e1b4b 0%, #2d1b6e 50%, #1a1040 100%);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 3rem 2.5rem;
        position: relative;
        overflow: hidden;
    }

    /* Decoración geométrica sutil */
    .split-left::before {
        content: '';
        position: absolute;
        top: -100px;
        right: -100px;
        width: 300px;
        height: 300px;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.06);
    }

    .split-left::after {
        content: '';
        position: absolute;
        bottom: -60px;
        left: -60px;
        width: 200px;
        height: 200px;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.04);
    }

    .split-left-inner {
        position: relative;
        z-index: 1;
    }

    .brand-mark {
        width: 44px;
        height: 44px;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 2.5rem;
    }

    .split-left h2 {
        font-family: system-ui, sans-serif;
        font-size: 1.625rem;
        font-weight: 700;
        color: #f1f5f9;
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
    }

    .split-left > .split-left-inner > p {
        font-family: system-ui, sans-serif;
        font-size: 0.9375rem;
        color: rgba(255,255,255,0.45);
        margin-bottom: 3rem;
    }

    .brand-features {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        font-family: system-ui, sans-serif;
        font-size: 0.875rem;
        color: rgba(255,255,255,0.6);
    }

    .feature-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: rgba(99,102,241,0.8);
        flex-shrink: 0;
    }

    .split-footer-brand {
        font-family: system-ui, sans-serif;
        font-size: 0.6875rem;
        color: rgba(255,255,255,0.2);
        position: relative;
        z-index: 1;
    }

    /* Panel derecho */
    .split-right {
        flex: 1;
        background: #09090f;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .form-wrapper {
        width: 100%;
        max-width: 360px;
        display: flex;
        flex-direction: column;
        gap: 1.125rem;
    }

    .form-header {
        margin-bottom: 0.5rem;
    }

    .form-header h1 {
        font-family: system-ui, sans-serif;
        font-size: 1.375rem;
        font-weight: 700;
        color: #f1f5f9;
        letter-spacing: -0.02em;
        margin-bottom: 0.375rem;
    }

    .form-header p {
        font-family: system-ui, sans-serif;
        font-size: 0.875rem;
        color: #475569;
    }

    .login-error {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0.625rem 0.875rem;
        background: rgba(239,68,68,0.07);
        border: 1px solid rgba(239,68,68,0.18);
        border-radius: 8px;
        font-family: system-ui, sans-serif;
        font-size: 0.8125rem;
        color: #fca5a5;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .form-group label {
        font-family: system-ui, sans-serif;
        font-size: 0.8125rem;
        font-weight: 500;
        color: #64748b;
    }

    .form-input {
        width: 100%;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 8px;
        padding: 0.6875rem 0.875rem;
        font-family: system-ui, sans-serif;
        font-size: 0.9375rem;
        color: #e2e8f0;
        outline: none;
        transition: border-color 0.15s, background 0.15s;
    }

    .form-input::placeholder { color: #1e293b; }

    .form-input:focus {
        border-color: rgba(99,102,241,0.45);
        background: rgba(99,102,241,0.04);
    }

    .form-input:disabled { opacity: 0.45; cursor: not-allowed; }

    .login-btn {
        width: 100%;
        margin-top: 4px;
        padding: 0.6875rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: #6366f1;
        color: white;
        border: none;
        border-radius: 8px;
        font-family: system-ui, sans-serif;
        font-size: 0.9375rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s;
    }

    .login-btn:hover:not(:disabled) { background: #5254cc; transform: translateY(-1px); }
    .login-btn:active:not(:disabled) { transform: translateY(0); }
    .login-btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

    .spinner {
        width: 14px;
        height: 14px;
        border: 2px solid rgba(255,255,255,0.25);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.65s linear infinite;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Responsive: en pantallas chicas el panel izquierdo se oculta */
    @@media (max-width: 640px) {
        .split-left { display: none; }
        .split-right { background: #09090f; }
    }
</style>

@code {
    private string _email    = "";
    private string _password = "";
    private string? _error   = null;
    private bool _loading    = false;

    protected override void OnInitialized()
    {
        if (Auth.IsAuthenticated)
            Nav.NavigateTo("/reconciliation");
    }

    private async Task HandleLogin()
    {
        _error   = null;
        _loading = true;

        try
        {
            var result = await AuthClient.LoginAsync(_email.Trim(), _password);

            if (result is null)
            {
                _error = "Email o contraseña incorrectos.";
                return;
            }

            Auth.SetUser(result.Token, result.Email, result.FullName,
                         result.Role, result.CompanyId, result.CompanyName, result.ExpiresAt);

            Nav.NavigateTo("/reconciliation");
        }
        catch
        {
            _error = "No se pudo conectar con el servidor. Intentá de nuevo.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }
}
