@page "/imports"
@using Microsoft.AspNetCore.Components.Forms
@using ReconciliationApp.Frontend.Services
@inject ReconciliationApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Imports</PageTitle>

<div class="card" style="padding:24px; margin-top:16px;">
  <h2 style="margin:0;">Imports</h2>
  <div class="small" style="color:var(--muted); margin-top:6px;">
    Subí los CSV de customers, deuda y pagos. Luego ejecutá la conciliación.
  </div>
</div>

@if (!string.IsNullOrWhiteSpace(PageError))
{
  <div class="card" style="padding:16px; margin-top:16px; border:1px solid rgba(239,68,68,.30);">
    <b>Error</b>
    <div style="margin-top:8px; color:var(--muted);">@PageError</div>
  </div>
}

@if (!string.IsNullOrWhiteSpace(PageSuccess))
{
  <div class="card" style="padding:16px; margin-top:16px; border:1px solid rgba(34,197,94,.30);">
    <b>OK</b>
    <div style="margin-top:8px; color:var(--muted);">@PageSuccess</div>
  </div>
}

<div class="card" style="padding:24px; margin-top:16px;">
  <h3 style="margin-top:0;">1. Crear sesión de importación</h3>

  <button class="btn primary"
          @onclick="CreateBatchAndRunAsync"
          disabled="@CreatingBatchAndRun">
    @(CreatingBatchAndRun ? "Creando sesión..." : "Crear sesión")
  </button>

  @if (BatchId is not null && RunNumber is not null)
  {
    <div class="small" style="margin-top:12px; color:var(--muted);">
      Batch: <b>@BatchId</b> · Run: <b>@RunNumber</b>
    </div>
  }
</div>

<div class="card" style="padding:24px; margin-top:16px;">
  <h3 style="margin-top:0;">2. CSV de customers</h3>

  <InputFile OnChange="OnCustomersFileSelected" accept=".csv" />

  <div class="small" style="margin-top:8px; color:var(--muted);">
    @CustomersFileStatus
  </div>

  <div style="margin-top:16px;">
    <button class="btn"
            @onclick="UploadCustomersAsync"
            disabled="@(!CanUploadCustomers)">
      @(UploadingCustomers ? "Subiendo..." : "Subir CSV de customers")
    </button>
  </div>
</div>

<div class="card" style="padding:24px; margin-top:16px;">
  <h3 style="margin-top:0;">3. CSV de deuda</h3>

  <InputFile OnChange="OnDebtFileSelected" accept=".csv" />

  <div class="small" style="margin-top:8px; color:var(--muted);">
    @DebtFileStatus
  </div>

  <div style="margin-top:16px;">
    <button class="btn"
            @onclick="UploadDebtAsync"
            disabled="@(!CanUploadDebt)">
      @(UploadingDebt ? "Subiendo..." : "Subir CSV de deuda")
    </button>
  </div>
</div>

<div class="card" style="padding:24px; margin-top:16px;">
  <h3 style="margin-top:0;">4. CSV de pagos</h3>

  <InputFile OnChange="OnPaymentsFileSelected" accept=".csv" />

  <div class="small" style="margin-top:8px; color:var(--muted);">
    @PaymentsFileStatus
  </div>

  <div style="margin-top:16px;">
    <button class="btn"
            @onclick="UploadPaymentsAsync"
            disabled="@(!CanUploadPayments)">
      @(UploadingPayments ? "Subiendo..." : "Subir CSV de pagos")
    </button>
  </div>
</div>

<div class="card" style="padding:24px; margin-top:16px;">
  <h3 style="margin-top:0;">5. Ejecutar conciliación</h3>

  <button class="btn primary"
          @onclick="ReconcileAsync"
          disabled="@(!CanReconcile)">
    @(Reconciling ? "Ejecutando..." : "Ejecutar conciliación")
  </button>
</div>

@code {
  private const long MaxCsvSizeBytes = 5 * 1024 * 1024;

  private Guid? BatchId;
  private int? RunNumber;

  private IBrowserFile? CustomersFile;
  private IBrowserFile? DebtFile;
  private IBrowserFile? PaymentsFile;

  private bool CreatingBatchAndRun;
  private bool UploadingCustomers;
  private bool UploadingDebt;
  private bool UploadingPayments;
  private bool Reconciling;

  private bool CustomersUploaded;
  private bool DebtUploaded;
  private bool PaymentsUploaded;

  private string? PageError;
  private string? PageSuccess;

  private string CustomersFileStatus =>
      CustomersUploaded ? "CSV de customers subido." :
      CustomersFile is null ? "Seleccioná archivo." :
      $"Archivo: {CustomersFile.Name}";

  private string DebtFileStatus =>
      DebtUploaded ? "CSV de deuda subido." :
      DebtFile is null ? "Seleccioná archivo." :
      $"Archivo: {DebtFile.Name}";

  private string PaymentsFileStatus =>
      PaymentsUploaded ? "CSV de pagos subido." :
      PaymentsFile is null ? "Seleccioná archivo." :
      $"Archivo: {PaymentsFile.Name}";

  private bool CanUploadCustomers =>
      BatchId is not null && RunNumber is not null &&
      CustomersFile is not null && !UploadingCustomers && !CustomersUploaded;

  private bool CanUploadDebt =>
      BatchId is not null && RunNumber is not null &&
      DebtFile is not null && !UploadingDebt && !DebtUploaded;

  private bool CanUploadPayments =>
      BatchId is not null && RunNumber is not null &&
      PaymentsFile is not null && !UploadingPayments && !PaymentsUploaded;

  private bool CanReconcile =>
      BatchId is not null && RunNumber is not null &&
      DebtUploaded && PaymentsUploaded && !Reconciling;

  private async Task CreateBatchAndRunAsync()
  {
      ClearMessages();
      CreatingBatchAndRun = true;

      try
      {
          // temporal: reemplazar cuando exista contexto real de company por usuario
          var companyId = Guid.Parse("00000000-0000-0000-0000-000000000001");

          var today = DateOnly.FromDateTime(DateTime.UtcNow);

          var batch = await ApiClient.CreateBatchAsync(companyId, today, today);
          if (batch is null)
          {
              PageError = "No se pudo crear el batch.";
              return;
          }

          var run = await ApiClient.CreateRunAsync(batch.BatchId);
          if (run is null)
          {
              PageError = "No se pudo crear el run.";
              return;
          }

          BatchId = run.BatchId;
          RunNumber = run.RunNumber;

          CustomersUploaded = false;
          DebtUploaded = false;
          PaymentsUploaded = false;

          PageSuccess = "Sesión creada correctamente.";
      }
      catch (Exception ex)
      {
          PageError = ex.Message;
      }
      finally
      {
          CreatingBatchAndRun = false;
      }
  }

  private Task OnCustomersFileSelected(InputFileChangeEventArgs args)
  {
      CustomersFile = args.File;
      CustomersUploaded = false;
      ClearMessages();
      return Task.CompletedTask;
  }

  private Task OnDebtFileSelected(InputFileChangeEventArgs args)
  {
      DebtFile = args.File;
      DebtUploaded = false;
      ClearMessages();
      return Task.CompletedTask;
  }

  private Task OnPaymentsFileSelected(InputFileChangeEventArgs args)
  {
      PaymentsFile = args.File;
      PaymentsUploaded = false;
      ClearMessages();
      return Task.CompletedTask;
  }

  private async Task UploadCustomersAsync()
  {
      ClearMessages();

      if (BatchId is null || RunNumber is null || CustomersFile is null)
      {
          PageError = "Primero creá la sesión y seleccioná el CSV de customers.";
          return;
      }

      UploadingCustomers = true;

      try
      {
          var csv = await ReadFileAsTextAsync(CustomersFile);
          var ok = await ApiClient.UploadCustomersCsvAsync(BatchId.Value, RunNumber.Value, csv);

          if (!ok)
          {
              PageError = "No se pudo subir el CSV de customers.";
              return;
          }

          CustomersUploaded = true;
          PageSuccess = "CSV de customers subido.";
      }
      catch (Exception ex)
      {
          PageError = ex.Message;
      }
      finally
      {
          UploadingCustomers = false;
      }
  }

  private async Task UploadDebtAsync()
  {
      ClearMessages();

      if (BatchId is null || RunNumber is null || DebtFile is null)
      {
          PageError = "Primero creá la sesión y seleccioná el CSV de deuda.";
          return;
      }

      UploadingDebt = true;

      try
      {
          var csv = await ReadFileAsTextAsync(DebtFile);
          var ok = await ApiClient.UploadDebtCsvAsync(BatchId.Value, RunNumber.Value, csv);

          if (!ok)
          {
              PageError = "No se pudo subir el CSV de deuda.";
              return;
          }

          DebtUploaded = true;
          PageSuccess = "CSV de deuda subido.";
      }
      catch (Exception ex)
      {
          PageError = ex.Message;
      }
      finally
      {
          UploadingDebt = false;
      }
  }

  private async Task UploadPaymentsAsync()
  {
      ClearMessages();

      if (BatchId is null || RunNumber is null || PaymentsFile is null)
      {
          PageError = "Primero creá la sesión y seleccioná el CSV de pagos.";
          return;
      }

      UploadingPayments = true;

      try
      {
          var csv = await ReadFileAsTextAsync(PaymentsFile);
          var ok = await ApiClient.UploadPaymentsCsvAsync(BatchId.Value, RunNumber.Value, csv);

          if (!ok)
          {
              PageError = "No se pudo subir el CSV de pagos.";
              return;
          }

          PaymentsUploaded = true;
          PageSuccess = "CSV de pagos subido.";
      }
      catch (Exception ex)
      {
          PageError = ex.Message;
      }
      finally
      {
          UploadingPayments = false;
      }
  }

  private async Task ReconcileAsync()
  {
      ClearMessages();

      if (BatchId is null || RunNumber is null)
      {
          PageError = "Primero creá la sesión.";
          return;
      }

      if (!DebtUploaded || !PaymentsUploaded)
      {
          PageError = "Tenés que subir deuda y pagos antes de conciliar.";
          return;
      }

      Reconciling = true;

      try
      {
          var result = await ApiClient.ReconcileAsync(BatchId.Value, RunNumber.Value);

          if (result is null)
          {
              PageError = "No se pudo ejecutar la conciliación.";
              return;
          }

          Navigation.NavigateTo($"/reconciliation/{result.BatchRunId}");
      }
      catch (Exception ex)
      {
          PageError = ex.Message;
      }
      finally
      {
          Reconciling = false;
      }
  }

  private static async Task<string> ReadFileAsTextAsync(IBrowserFile file)
  {
      await using var stream = file.OpenReadStream(MaxCsvSizeBytes);
      using var reader = new StreamReader(stream);
      return await reader.ReadToEndAsync();
  }

  private void ClearMessages()
  {
      PageError = null;
      PageSuccess = null;
  }
}